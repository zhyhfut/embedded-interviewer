# ============================================================
# LLM Provider 配置（至少配置一个）
# ============================================================
# 可选值: claude / openai / xiaomi / doubao / custom
LLM_PROVIDER=claude

# ---- Claude (Anthropic) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- 小米 MiMo（OpenAI 兼容接口）----
# 申请地址：https://api.xiaomi.com
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomi.com/v1
XIAOMI_MODEL=MiMo

# ---- 豆包 / 字节跳动（OpenAI 兼容接口）----
# 申请地址：https://console.volcengine.com/ark
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-256k

# ---- 自定义 OpenAI 兼容接口 ----
# 适用于本地部署模型（ollama、vLLM、LM Studio 等）或其他兼容服务
CUSTOM_API_KEY=not-needed
CUSTOM_BASE_URL=http://localhost:11434/v1
CUSTOM_MODEL=qwen2.5:14b

# ============================================================
# 飞书集成（可选，不配置则无法读取飞书文档和导出报告到飞书）
# ============================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ============================================================
# 服务配置
# ============================================================
HOST=0.0.0.0
PORT=8000

# 数据存储目录（简历缓存等）
DATA_DIR=./data
